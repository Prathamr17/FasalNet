# FasalNet Backend — Environment Variables
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fasalnet
DB_USER=postgres
DB_PASSWORD=password

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-jwt-key-change-in-production
SECRET_KEY=your-flask-secret-key

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Flask ─────────────────────────────────────────────────
FLASK_DEBUG=0

# ── Email / SMTP (Gmail recommended) ─────────────────────
# Use Gmail App Password (not your regular password)
# Enable 2FA on Gmail → App Passwords → Generate
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SENDER_EMAIL=your_gmail@gmail.com
SENDER_NAME=FasalNet

# ── OTP Settings ─────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5
RESEND_COOLDOWN_SECONDS=60

# ── ML Models (Google Drive file IDs) ────────────────────────
# Get file ID from the share link:
# https://drive.google.com/file/d/FILE_ID_HERE/view
# Folder: https://drive.google.com/drive/folders/18u0uOj2TzhVUsZO9a0GxRRKaNnYxTXA8
GDRIVE_PRICE_MODEL_ID=your_price_model_file_id
GDRIVE_CLASSIFY_MODEL_ID=your_classification_model_file_id
GDRIVE_MARKET_MODEL_ID=your_market_recommendation_file_id

# FasalNet v8 — Frontend Environment Variables
# Copy this file to .env and fill in the values

# Backend API URL
REACT_APP_API_URL=http://localhost:5000

# Google OAuth Client ID (for Google Sign-In button)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# MapFlow / Routing — No extra key needed (uses OpenStreetMap + OSRM)
# The map works with OpenStreetMap tiles (free, no key)
# Routing uses leaflet-routing-machine with OSRM (free, no key)
# For Nominatim geocoding: no key required for low-volume usage

# Email / OTP Configuration (set these in backend .env)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_gmail@gmail.com
# SMTP_PASSWORD=your_app_password
# SENDER_EMAIL=your_gmail@gmail.com
# SENDER_NAME=FasalNet
